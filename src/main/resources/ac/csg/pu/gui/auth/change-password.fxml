<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ac.csg.pu.gui.auth.ChangePasswordController"
      stylesheets="@auth.css"
      styleClass="auth-container">

    <Label text="Change Password" styleClass="auth-title"/>
    <Label text="You must change your password before continuing."/>

    <PasswordField fx:id="newPasswordField" promptText="New password"/>

    <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"/>

    <Button text="Submit" onAction="#onSubmit" styleClass="auth-button"/>

    <Label fx:id="errorLabel" styleClass="auth-error"/>
</VBox>